{
  "name": "react-native-preflight",
  "version": "0.1.1",
  "description": "Simplify Maestro E2E testing for React Native — isolated screen tests, dev catalog, visual regression",
  "source": "./src/index.tsx",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./babel": {
      "types": "./lib/babel/strip-preflight.d.ts",
      "default": "./lib/babel/strip-preflight.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "preflight": "./lib/cli/index.js"
  },
  "files": [
    "src",
    "lib",
    "skills",
    ".claude-plugin",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "example": "npm --prefix example",
    "clean": "del-cli lib",
    "prepare": "bob build --target module && tsc -p tsconfig.build.json --declaration --declarationMap --emitDeclarationOnly --noEmit false --outDir lib/typescript && tsc -p cli/tsconfig.json && tsc -p babel/tsconfig.json && echo '#!/usr/bin/env node' | cat - lib/cli/index.js > lib/cli/index.tmp.js && mv lib/cli/index.tmp.js lib/cli/index.js",
    "test": "jest",
    "test:cli": "jest --config cli/jest.config.js",
    "test:babel": "jest --config babel/jest.config.js",
    "test:all": "npm test && npm run test:cli && npm run test:babel",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:ts": "tsc",
    "format:check": "prettier \"src/**/*.{js,ts,tsx}\" --check",
    "format:write": "prettier \"src/**/*.{js,ts,tsx}\" --write"
  },
  "keywords": [
    "react-native",
    "maestro",
    "testing",
    "e2e",
    "screenshots",
    "visual-regression"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RamboWasReal/react-native-preflight.git"
  },
  "homepage": "https://github.com/RamboWasReal/react-native-preflight#readme",
  "bugs": {
    "url": "https://github.com/RamboWasReal/react-native-preflight/issues"
  },
  "author": "David Boutin",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "expo-linking": ">=54.0.0",
    "expo-router": ">=54.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "expo-linking": {
      "optional": false
    },
    "expo-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "commander": "^12.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@babel/types": "^7.26.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7",
    "@types/babel__traverse": "^7.20.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19",
    "@typescript-eslint/parser": "^8.57.1",
    "babel-jest": "^30.3.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-linking": "^55.0.8",
    "expo-router": "^55.0.7",
    "jest": "^30.2.0",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.18",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false
  },
  "packageManager": "yarn@4.13.0"
}

{
  "compilerOptions": {
    "outDir": "../lib/cli",
    "rootDir": ".",
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["./**/*.ts"],
  "exclude": ["__tests__"]
}
